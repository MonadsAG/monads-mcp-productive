{
  "permissions": {
    "allow": [
      "Bash(npm install:*)",
      "Bash(python productive_to_openapi.py)"
    ]
  },
  "enabledPlugins": {
    "mcp-server-dev@claude-plugins-official": true
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "npx prettier --write $CLAUDE_FILE_PATH",
            "timeout": 10000
          }
        ]
      }
    ]
  }
}
